<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    sensors.xacro
    传感器模块：摄像头 + 激光雷达
    父连杆：turret_link（摄像头）、sensor_mast_link（激光雷达）
    frame_id 必须与 TF 树一致：camera_optical_link / lidar_link
  -->

  <xacro:property name="PI" value="3.14159265358979"/>

  <!-- ===== 摄像头连杆 ===== -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.06 0.12 0.06"/>
      </geometry>
      <material name="sensor_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.12 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- 摄像头挂载到回转体前端，高于中心 0.1m，距轴线 1.3m -->
  <joint name="camera_joint" type="fixed">
    <parent link="turret_link"/>
    <child  link="camera_link"/>
    <origin xyz="1.3 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- 摄像头光学坐标系：ROS 惯例 Z 轴朝前，X 朝右 -->
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="${-PI/2} 0 ${-PI/2}"/>
  </joint>

  <!-- ===== 激光雷达连杆 ===== -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.055" length="0.09"/>
      </geometry>
      <material name="sensor_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.055" length="0.09"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <!-- cylinder: Ixx=Iyy=m(3r²+h²)/12, Izz=mr²/2 -->
      <inertia ixx="0.000367" ixy="0" ixz="0"
               iyy="0.000367" iyz="0"
               izz="0.000379"/>
    </inertial>
  </link>

  <!-- 激光雷达挂载到传感器支架顶端 0.3m -->
  <joint name="lidar_joint" type="fixed">
    <parent link="sensor_mast_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
  </joint>

  <!-- ===== Gazebo 插件：摄像头 ===== -->
  <gazebo reference="camera_link">
    <sensor type="camera" name="front_camera">
      <update_rate>30.0</update_rate>
      <camera name="head">
        <!-- 水平视角 90° -->
        <horizontal_fov>1.5708</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>30.0</updateRate>
        <cameraName>camera</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <!-- frameName 必须与 TF 中 camera_optical_link 一致 -->
        <frameName>camera_optical_link</frameName>
        <hackBaseline>0.0</hackBaseline>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ===== Gazebo 插件：激光雷达 ===== -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <!-- 仿真中不显示射线（正式测试），调试时改为 true -->
      <visualize>false</visualize>
      <update_rate>10.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <!-- 360°，1° 分辨率 = 360 采样 -->
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle>3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>15.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_laser.so">
        <topicName>/lidar/scan</topicName>
        <!-- frameName 与 TF lidar_link 一致 -->
        <frameName>lidar_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

</robot>
