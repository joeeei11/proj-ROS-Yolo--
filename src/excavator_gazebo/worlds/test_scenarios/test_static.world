<?xml version="1.0"?>
<!-- test_static.world: 3个静态障碍物，验证绕行成功 -->
<sdf version="1.6">
  <world name="test_static">

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <!-- 围栏（高 5m，确保激光雷达 z≈2.95m 扫描面穿过围栏） -->
    <model name="fence_north">
      <static>true</static><pose>6 15 2.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>42 0.2 5.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>42 0.2 5.0</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/WoodFloor</name></script></material>
        </visual>
      </link>
    </model>
    <model name="fence_south">
      <static>true</static><pose>6 -15 2.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>42 0.2 5.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>42 0.2 5.0</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/WoodFloor</name></script></material>
        </visual>
      </link>
    </model>

    <!--
      Static obstacle layout (excavator starts at x=0,y=0; goal x=18,y=0):
      obs_A is 5m ahead and forces a detour.
      obs_B is moved right to y=7m to preserve EC650 clearance.
      obs_C is moved left to y=-7m to form an S-shaped detour.

      Obstacle height is 3.5m (center z=1.75m), so the lidar scan plane
      at z~2.95m intersects the obstacle volumes.
    -->
    <model name="obstacle_A">
      <static>true</static>
      <pose>5.0 0.0 1.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.0 1.0 3.5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>1.0 1.0 3.5</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Grey</name></script></material>
        </visual>
      </link>
    </model>

    <model name="obstacle_B">
      <static>true</static>
      <pose>11.0 5.0 1.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.8 0.8 3.5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>0.8 0.8 3.5</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Red</name></script></material>
        </visual>
      </link>
    </model>

    <model name="obstacle_C">
      <static>true</static>
      <pose>17.0 0.0 1.75 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>1.2 1.0 3.5</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>1.2 1.0 3.5</size></box></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Blue</name></script></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
