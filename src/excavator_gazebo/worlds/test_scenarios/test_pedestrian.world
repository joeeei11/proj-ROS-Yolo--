<?xml version="1.0"?>
<!-- test_pedestrian.world: 1个随机游走行人，验证 PAUSED + 自动恢复 -->
<sdf version="1.6">
  <world name="test_pedestrian">

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <!--
      行人 Actor：从挖掘机侧方经过，进入安全距离后离开
      行走路径：从 (8, 5) 经过 (4, 0) 再走到 (8, -5)，
               最近点约 (4, 0)，距挖掘机 (0,0) 约 4m
               → lidar_processor 扇区距离 < safe_distance(5m)，触发 MEDIUM/HIGH
    -->
    <actor name="pedestrian_1">
      <pose>8.0 5.0 1.0 0 0 -1.5708</pose>
      <skin>
        <filename>walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walking">
        <filename>walk.dae</filename>
        <scale>1.000000</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <script>
        <loop>true</loop>
        <delay_start>2.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walking">
          <!-- 路径点：从侧方接近后绕过 -->
          <waypoint>
            <time>0.0</time>
            <pose>8.0 5.0 0.0 0 0 -1.5708</pose>
          </waypoint>
          <waypoint>
            <time>5.0</time>
            <pose>4.0 2.0 0.0 0 0 -2.0</pose>
          </waypoint>
          <waypoint>
            <time>8.0</time>
            <pose>2.0 0.0 0.0 0 0 -3.14</pose>
          </waypoint>
          <waypoint>
            <time>11.0</time>
            <pose>2.0 -3.0 0.0 0 0 -1.5708</pose>
          </waypoint>
          <waypoint>
            <time>15.0</time>
            <pose>8.0 -5.0 0.0 0 0 -0.5</pose>
          </waypoint>
          <!-- 返回路径（形成循环） -->
          <waypoint>
            <time>20.0</time>
            <pose>8.0 5.0 0.0 0 0 1.5708</pose>
          </waypoint>
        </trajectory>
      </script>
    </actor>

    <!-- 路径标记（可视化行人通道） -->
    <model name="path_marker_start">
      <static>true</static>
      <pose>8.0 5.0 0.05 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><cylinder><radius>0.2</radius><length>0.1</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Green</name></script></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
