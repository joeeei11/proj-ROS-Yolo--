<?xml version="1.0"?>
<!-- test_multi_threat.world: 2行人+1车辆同时出现，验证最高等级驱动FSM -->
<sdf version="1.6">
  <world name="test_multi_threat">

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <!--
      多威胁场景：
        行人1 (pedestrian_left)：从左侧接近，到最近距离约 3m → HIGH (type_weight=1.5)
        行人2 (pedestrian_right)：从右侧接近，到最近距离约 6m → LOW
        车辆 (vehicle_front)：从正面接近，初始距离 15m，速度 3m/s → TTC 随时间减小

      验证目标：FSM 的 dominant_risk_level = max(行人1.HIGH, 行人2.LOW, 车辆.MEDIUM/HIGH)
               应始终为 HIGH，触发 EMERGENCY_STOP
    -->

    <!-- 行人1：左侧接近 -->
    <actor name="pedestrian_left">
      <pose>0.0 8.0 1.0 0 0 -1.5708</pose>
      <skin>
        <filename>walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walking">
        <filename>walk.dae</filename>
        <scale>1.0</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <script>
        <loop>true</loop>
        <delay_start>1.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walking">
          <waypoint><time>0.0</time><pose>0.0 8.0 0.0 0 0 -1.5708</pose></waypoint>
          <waypoint><time>4.0</time><pose>0.0 3.0 0.0 0 0 -1.5708</pose></waypoint>
          <waypoint><time>6.0</time><pose>0.0 1.5 0.0 0 0 -1.5708</pose></waypoint>
          <waypoint><time>9.0</time><pose>0.0 3.0 0.0 0 0 1.5708</pose></waypoint>
          <waypoint><time>13.0</time><pose>0.0 8.0 0.0 0 0 1.5708</pose></waypoint>
        </trajectory>
      </script>
    </actor>

    <!-- 行人2：右侧远距离 -->
    <actor name="pedestrian_right">
      <pose>2.0 -8.0 1.0 0 0 1.5708</pose>
      <skin>
        <filename>walk.dae</filename>
        <scale>1.0</scale>
      </skin>
      <animation name="walking">
        <filename>walk.dae</filename>
        <scale>1.0</scale>
        <interpolate_x>true</interpolate_x>
      </animation>
      <script>
        <loop>true</loop>
        <delay_start>0.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="walking">
          <waypoint><time>0.0</time><pose>2.0 -8.0 0.0 0 0 1.5708</pose></waypoint>
          <waypoint><time>5.0</time><pose>2.0 -5.0 0.0 0 0 1.5708</pose></waypoint>
          <waypoint><time>8.0</time><pose>2.0 -8.0 0.0 0 0 -1.5708</pose></waypoint>
        </trajectory>
      </script>
    </actor>

    <!-- 车辆：从正面直线驶来，由 obstacle_spawner 控制速度 -->
    <model name="vehicle_front">
      <pose>15.0 0.0 0.5 0 0 3.14159</pose>
      <link name="body">
        <inertial>
          <mass>1500.0</mass>
          <inertia>
            <ixx>500</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>2000</iyy><iyz>0</iyz>
            <izz>2000</izz>
          </inertia>
        </inertial>
        <collision name="c">
          <geometry><box><size>4.5 2.0 1.5</size></box></geometry>
        </collision>
        <visual name="v">
          <geometry><box><size>4.5 2.0 1.5</size></box></geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Orange</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

    <!-- 标记：挖掘机起始位置 -->
    <model name="origin_marker">
      <static>true</static>
      <pose>0 0 0.05 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><cylinder><radius>0.4</radius><length>0.1</length></cylinder></geometry>
          <material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Green</name></script></material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
