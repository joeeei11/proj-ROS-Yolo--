<launch>
  <!-- Gazebo 仿真世界启动（Step1） -->
  <arg name="world_name"
       default="$(find excavator_gazebo)/worlds/construction_site.world"/>
  <arg name="gui"     default="false"/>
  <arg name="paused"  default="false"/>
  <arg name="model_variant" default="ec650"/>

  <!-- 启动 Gazebo -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world_name)"/>
    <arg name="gui"        value="$(arg gui)"/>
    <arg name="paused"     value="$(arg paused)"/>
    <arg name="use_sim_time" value="true"/>
  </include>

  <!-- 加载机器人描述到参数服务器 -->
  <param name="robot_description"
         command="$(find xacro)/xacro
                  $(find excavator_description)/urdf/excavator.urdf.xacro"
         if="$(eval arg('model_variant') == 'ec650')"/>
  <param name="robot_description"
         command="$(find xacro)/xacro
                  $(find excavator_description)/urdf/excavator_simple.urdf.xacro"
         if="$(eval arg('model_variant') == 'simple')"/>

  <!-- 在 Gazebo 中生成机器人 -->
  <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model"
        args="-urdf -model excavator -param robot_description
              -x 0 -y 0 -z 0.1"
        output="screen"/>

  <!-- joint_state_publisher：发布所有非固定关节的状态（必需，否则 turret/boom/arm/bucket 的 TF 链断开） -->
  <node name="joint_state_publisher" pkg="joint_state_publisher"
        type="joint_state_publisher" output="screen">
    <param name="rate" value="50"/>
    <param name="use_gui" value="false"/>
  </node>

  <!-- robot_state_publisher -->
  <node name="robot_state_publisher" pkg="robot_state_publisher"
        type="robot_state_publisher" output="screen">
    <param name="publish_frequency" value="50.0"/>
  </node>

</launch>
